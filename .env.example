# Atlas Marketing Studio — Vercel/local Next.js environment variables.
# Cloudflare uses D1/R2 bindings instead of DATABASE_URL/BLOB_READ_WRITE_TOKEN.

ATLASCLOUD_API_KEY="apikey-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
ATLASCLOUD_BASE="https://api.atlascloud.ai/api/v1"

# Vercel database: pooled Neon URL for runtime and optional direct URL for
# `npm run db:push:vercel`.
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"

# Connect a PUBLIC Vercel Blob store to the project. Vercel normally injects
# this variable automatically.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_xxxxxxxxxxxxxxxxx"

# Optional while existing records still reference Cloudflare R2 paths.
CLOUDFLARE_MEDIA_BASE_URL="https://your-worker.workers.dev"

NEXTAUTH_SECRET="change-me"
NEXTAUTH_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

PAYMENT_PROVIDER="atlas"

# Required only when PAYMENT_PROVIDER=stripe.
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# Required only when PAYMENT_PROVIDER=atlas.
KUBEDL_ADMIN_BASE="https://console.atlascloud.ai/api/v1"
KUBEDL_ADMIN_APIKEY=""
KUBEDL_ATLAS_HEADER=""
ATLAS_REDEEM_CREDITS="100"

SIGNUP_BONUS_CREDITS="20"

# Local override only. Vercel sets VERCEL=1 automatically.
# DEPLOY_TARGET="vercel"
