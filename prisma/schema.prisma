// Atlas SaaS Starter — data model
// Postgres in production (Supabase / Neon / Vercel Postgres).
// For zero-config local dev you can switch provider to "sqlite"
// and set DATABASE_URL="file:./dev.db" (remove directUrl).

generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider  = "sqlite"
  url       = env("DATABASE_URL")
}

// ── NextAuth standard models ──
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  credits       Int       @default(0) // current balance snapshot
  createdAt     DateTime  @default(now())

  accounts  Account[]
  sessions  Session[]
  creations Creation[]
  ledger    CreditLedger[]
  adProducts AdProduct[]
  adAvatars  AdAvatar[]
  brandKits  BrandKit[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ── App models ──
model Creation {
  id         String   @id @default(cuid())
  userId     String
  templateId String
  model      String
  prompt     String  
  inputImage String? 
  status     String   @default("pending") // pending | processing | completed | failed
  taskId     String?
  getUrl     String? 
  outputs    Json?
  assets     Json?    // drama 作品文件夹:结构化中间资产(kind/characters[定妆图]/sceneImage/scenes[首帧+视频]/finalVideo);其它类型为 null
  error      String?
  cost       Int      @default(0) // credits charged
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CreditLedger {
  id        String   @id @default(cuid())
  userId    String
  delta     Int // +grant / -spend
  reason    String // signup | purchase | redeem | generate | refund
  ref       String? // stripe session id / cdkey / creation id
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Prevents the same Atlas redeem code being used twice in this app.
model RedeemedCode {
  code      String   @id
  userId    String
  amount    Int
  createdAt DateTime @default(now())
}

// ── Marketing Studio 资产层(可复用资产,复刻 Higgsfield Product/Avatar/BrandKit) ──
model AdProduct {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String   // 英文产品锚(锁跨镜一致)
  imageUrl    String?  // 产品参考图 URL
  sourceUrl   String?  // URL 导入来源
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AdAvatar {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String   // 英文人物描述
  imageUrl    String?  // 数字人定妆图 URL
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BrandKit {
  id        String   @id @default(cuid())
  userId    String
  name      String
  logoUrl   String? 
  colors    Json? // 品牌色数组
  fontNote  String?
  toneNote  String?  // 语气/风格
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
